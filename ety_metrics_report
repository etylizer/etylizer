#!/usr/bin/env escript
%%! -noinput

main(Args) ->
    {Title, Rest} = case Args of
        ["--title", T | R] -> {T, R};
        R -> {undefined, R}
    end,
    case Rest of
        [PrFile] -> report(Title, load_json(PrFile), #{});
        [PrFile, BaseFile] -> report(Title, load_json(PrFile), load_json(BaseFile));
        _ ->
            io:format(standard_error, "Usage: ety_metrics_report [--title TITLE] <pr.json> [base.json]~n", []),
            halt(1)
    end.

load_json(Path) ->
    {ok, Bin} = file:read_file(Path),
    json:decode(Bin).

report(Title, Pr, Base) ->
    HasBase = maps:size(Base) > 0,
    % Typecheck time sections
    case maps:find(<<"typecheck_time">>, Pr) of
        {ok, PrEntries} ->
            BaseEntries = maps:get(<<"typecheck_time">>, Base, []),
            print_time_section(section_title(Title, "Typecheck Statistics"), "function", PrEntries, BaseEntries, HasBase);
        error -> ok
    end,
    % Poly vars section
    case maps:find(<<"poly_vars">>, Pr) of
        {ok, PrPoly} ->
            BasePoly = maps:get(<<"poly_vars">>, Base, []),
            print_poly_section(section_title(Title, "Polymorphic Variable Statistics"), PrPoly, BasePoly, HasBase);
        error -> ok
    end.

section_title(undefined, Section) -> Section;
section_title(Title, Section) -> Title ++ ": " ++ Section.

%% --- Time statistics ---

time_stats([]) ->
    #{total => 0, ok => 0, errors => 0, timeouts => 0,
      total_time => 0, avg => 0.0, max => {0, <<>>}, min => {0, <<>>}};
time_stats(Entries) ->
    {Ok, Err, Tout, Times} = lists:foldl(
        fun([Name, Time, Status], {O, E, T, Ts}) ->
            Entry = {Name, Time},
            case Status of
                <<"ok">>      -> {O+1, E, T, [Entry|Ts]};
                <<"error">>   -> {O, E+1, T, [Entry|Ts]};
                <<"timeout">> -> {O, E, T+1, [Entry|Ts]};
                _             -> {O, E, T, [Entry|Ts]}
            end
        end,
        {0, 0, 0, []},
        Entries
    ),
    Total = length(Entries),
    TotalTime = lists:sum([T || {_, T} <- Times]),
    Avg = TotalTime / max(1, Total),
    {MaxN, MaxT} = lists:foldl(
        fun({N,T}, {_, BT}) when T > BT -> {N,T}; (_, Acc) -> Acc end,
        {<<>>, 0}, Times),
    {MinN, MinT} = lists:foldl(
        fun({N,T}, {_, BT}) when T < BT -> {N,T}; (_, Acc) -> Acc end,
        {<<>>, infinity}, Times),
    MinVal = case MinT of infinity -> 0; V -> V end,
    #{total => Total, ok => Ok, errors => Err, timeouts => Tout,
      total_time => TotalTime, avg => Avg,
      max => {MaxT, MaxN}, min => {MinVal, MinN}}.

print_time_section(Title, Unit, PrEntries, BaseEntries, HasBase) ->
    PrS = time_stats(PrEntries),
    io:format("## ~s~n~n", [Title]),
    case HasBase of
        true ->
            BaseS = time_stats(BaseEntries),
            io:format("| Metric | PR | Base | Delta |~n", []),
            io:format("|--------|----|------|-------|~n", []),
            row3("Total " ++ Unit ++ "s", ival(maps:get(total, PrS)), ival(maps:get(total, BaseS)),
                 delta_int(maps:get(total, PrS), maps:get(total, BaseS))),
            row3("OK", ival(maps:get(ok, PrS)), ival(maps:get(ok, BaseS)),
                 delta_int(maps:get(ok, PrS), maps:get(ok, BaseS))),
            row3("Errors", ival(maps:get(errors, PrS)), ival(maps:get(errors, BaseS)),
                 delta_int(maps:get(errors, PrS), maps:get(errors, BaseS))),
            row3("Timeouts", ival(maps:get(timeouts, PrS)), ival(maps:get(timeouts, BaseS)),
                 delta_int(maps:get(timeouts, PrS), maps:get(timeouts, BaseS))),
            row3("Total time", fmt_time(maps:get(total_time, PrS)), fmt_time(maps:get(total_time, BaseS)),
                 delta_time(maps:get(total_time, PrS), maps:get(total_time, BaseS))),
            row3("Avg per " ++ Unit, fmt_ms1(maps:get(avg, PrS)), fmt_ms1(maps:get(avg, BaseS)),
                 delta_ms1(maps:get(avg, PrS), maps:get(avg, BaseS))),
            {PrMaxT, PrMaxN} = maps:get(max, PrS),
            {BaseMaxT, BaseMaxN} = maps:get(max, BaseS),
            row3("Max", fmt_ms_name(PrMaxT, PrMaxN), fmt_ms_name(BaseMaxT, BaseMaxN),
                 delta_time(PrMaxT, BaseMaxT)),
            {PrMinT, PrMinN} = maps:get(min, PrS),
            {BaseMinT, BaseMinN} = maps:get(min, BaseS),
            row3("Min", fmt_ms_name(PrMinT, PrMinN), fmt_ms_name(BaseMinT, BaseMinN),
                 delta_time(PrMinT, BaseMinT));
        false ->
            io:format("| Metric | Value |~n", []),
            io:format("|--------|-------|~n", []),
            row1("Total " ++ Unit ++ "s", ival(maps:get(total, PrS))),
            row1("OK", ival(maps:get(ok, PrS))),
            row1("Errors", ival(maps:get(errors, PrS))),
            row1("Timeouts", ival(maps:get(timeouts, PrS))),
            row1("Total time", fmt_time(maps:get(total_time, PrS))),
            row1("Avg per " ++ Unit, fmt_ms1(maps:get(avg, PrS))),
            {PrMaxT, PrMaxN} = maps:get(max, PrS),
            row1("Max", fmt_ms_name(PrMaxT, PrMaxN)),
            {PrMinT, PrMinN} = maps:get(min, PrS),
            row1("Min", fmt_ms_name(PrMinT, PrMinN))
    end,
    io:format("~n", []).

%% --- Poly var statistics ---

poly_stats([]) ->
    #{invocations => 0, total_poly => 0, total_mono => 0,
      avg_poly => 0.0, avg_mono => 0.0,
      min_poly => 0, min_mono => 0, max_poly => 0, max_mono => 0};
poly_stats(Entries) ->
    Polys = [P || [P, _] <- Entries],
    Monos = [M || [_, M] <- Entries],
    N = length(Entries),
    #{invocations => N,
      total_poly => lists:sum(Polys), total_mono => lists:sum(Monos),
      avg_poly => lists:sum(Polys) / max(1, N), avg_mono => lists:sum(Monos) / max(1, N),
      min_poly => lists:min(Polys), min_mono => lists:min(Monos),
      max_poly => lists:max(Polys), max_mono => lists:max(Monos)}.

print_poly_section(Title, PrEntries, BaseEntries, HasBase) ->
    PrS = poly_stats(PrEntries),
    io:format("## ~s~n~n", [Title]),
    case HasBase of
        true ->
            BaseS = poly_stats(BaseEntries),
            io:format("| Metric | PR Poly | PR Mono | Base Poly | Base Mono | Delta Poly | Delta Mono |~n", []),
            io:format("|--------|---------|---------|-----------|-----------|------------|------------|~n", []),
            poly_row3("Invocations",
                ival(maps:get(invocations, PrS)), ival(maps:get(invocations, PrS)),
                ival(maps:get(invocations, BaseS)), ival(maps:get(invocations, BaseS)),
                delta_int(maps:get(invocations, PrS), maps:get(invocations, BaseS)),
                delta_int(maps:get(invocations, PrS), maps:get(invocations, BaseS))),
            poly_row3("Total vars",
                ival(maps:get(total_poly, PrS)), ival(maps:get(total_mono, PrS)),
                ival(maps:get(total_poly, BaseS)), ival(maps:get(total_mono, BaseS)),
                delta_int(maps:get(total_poly, PrS), maps:get(total_poly, BaseS)),
                delta_int(maps:get(total_mono, PrS), maps:get(total_mono, BaseS))),
            poly_row3("Avg vars",
                fmt_f1(maps:get(avg_poly, PrS)), fmt_f1(maps:get(avg_mono, PrS)),
                fmt_f1(maps:get(avg_poly, BaseS)), fmt_f1(maps:get(avg_mono, BaseS)),
                delta_f1(maps:get(avg_poly, PrS), maps:get(avg_poly, BaseS)),
                delta_f1(maps:get(avg_mono, PrS), maps:get(avg_mono, BaseS))),
            poly_row3("Min vars",
                ival(maps:get(min_poly, PrS)), ival(maps:get(min_mono, PrS)),
                ival(maps:get(min_poly, BaseS)), ival(maps:get(min_mono, BaseS)),
                delta_int(maps:get(min_poly, PrS), maps:get(min_poly, BaseS)),
                delta_int(maps:get(min_mono, PrS), maps:get(min_mono, BaseS))),
            poly_row3("Max vars",
                ival(maps:get(max_poly, PrS)), ival(maps:get(max_mono, PrS)),
                ival(maps:get(max_poly, BaseS)), ival(maps:get(max_mono, BaseS)),
                delta_int(maps:get(max_poly, PrS), maps:get(max_poly, BaseS)),
                delta_int(maps:get(max_mono, PrS), maps:get(max_mono, BaseS)));
        false ->
            io:format("| Metric | Poly | Mono |~n", []),
            io:format("|--------|------|------|~n", []),
            row2("Invocations", ival(maps:get(invocations, PrS)), ival(maps:get(invocations, PrS))),
            row2("Total vars", ival(maps:get(total_poly, PrS)), ival(maps:get(total_mono, PrS))),
            row2("Avg vars", fmt_f1(maps:get(avg_poly, PrS)), fmt_f1(maps:get(avg_mono, PrS))),
            row2("Min vars", ival(maps:get(min_poly, PrS)), ival(maps:get(min_mono, PrS))),
            row2("Max vars", ival(maps:get(max_poly, PrS)), ival(maps:get(max_mono, PrS)))
    end,
    io:format("~n", []).

%% --- Table row helpers ---

row1(Metric, Val) ->
    io:format("| ~s | ~s |~n", [Metric, Val]).

row2(Metric, V1, V2) ->
    io:format("| ~s | ~s | ~s |~n", [Metric, V1, V2]).

row3(Metric, Pr, Base, Delta) ->
    io:format("| ~s | ~s | ~s | ~s |~n", [Metric, Pr, Base, Delta]).

poly_row3(Metric, PrP, PrM, BaseP, BaseM, DeltaP, DeltaM) ->
    io:format("| ~s | ~s | ~s | ~s | ~s | ~s | ~s |~n", [Metric, PrP, PrM, BaseP, BaseM, DeltaP, DeltaM]).

%% --- Formatting ---

ival(N) -> integer_to_list(N).

fmt_f1(F) -> io_lib:format("~.1f", [F]).

fmt_time(Ms) when Ms >= 60000 ->
    Min = Ms div 60000,
    Sec = (Ms rem 60000) / 1000,
    case round(Sec) == trunc(Sec) andalso Sec >= 1.0 of
        true -> io_lib:format("~Bm ~Bs", [Min, round(Sec)]);
        false when Sec < 1.0 -> io_lib:format("~Bm ~.1fs", [Min, Sec]);
        false -> io_lib:format("~Bm ~.1fs", [Min, Sec])
    end;
fmt_time(Ms) when Ms >= 1000 ->
    io_lib:format("~.1fs", [Ms / 1000]);
fmt_time(Ms) ->
    io_lib:format("~Bms", [Ms]).

fmt_ms1(F) ->
    io_lib:format("~.1fms", [F]).

fmt_ms_name(Ms, Name) when is_binary(Name), byte_size(Name) > 0 ->
    io_lib:format("~Bms (`~s`)", [Ms, Name]);
fmt_ms_name(Ms, _) ->
    io_lib:format("~Bms", [Ms]).

delta_int(Pr, Base) ->
    D = Pr - Base,
    case D of
        0 -> "0";
        _ when D > 0 -> io_lib:format("+~B", [D]);
        _ -> integer_to_list(D)
    end.

delta_time(Pr, Base) ->
    D = Pr - Base,
    case D of
        0 -> "0";
        _ when D > 0 -> "+" ++ lists:flatten(fmt_time_delta(D));
        _ -> lists:flatten(fmt_time_delta(D))
    end.

delta_ms1(Pr, Base) ->
    D = Pr - Base,
    case abs(D) < 0.05 of
        true -> "0";
        false when D > 0 -> io_lib:format("+~.1fms", [D]);
        false -> io_lib:format("~.1fms", [D])
    end.

delta_f1(Pr, Base) ->
    D = Pr - Base,
    case abs(D) < 0.05 of
        true -> "0";
        false when D > 0 -> io_lib:format("+~.1f", [D]);
        false -> io_lib:format("~.1f", [D])
    end.

fmt_time_delta(Ms) when abs(Ms) >= 1000 ->
    io_lib:format("~.1fs", [Ms / 1000]);
fmt_time_delta(Ms) ->
    io_lib:format("~Bms", [Ms]).
