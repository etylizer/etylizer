#!/bin/bash
set -e

# Typechecks the WHOLE etylizer project (every .erl under ./src, which recurses
# into ./src/erlang_types). Goal: every function reports `Ok:`.
#
# -S ./src selects the files to typecheck; --no-deps means dependency modules
# are parsed for their specs but their bodies are not re-checked here. The
# overlay supplies specs for stdlib / FFI boundaries (lists:foldl, ets, ...).
#
# Each `-i module:fun/arity` below suppresses one function. Every ignore MUST
# carry a comment explaining *why* it cannot be fixed by improving a spec,
# narrowing, fixing a producer, or an ?assert. An ignore is the last resort.
#
# ============================================================================
# IGNORE LEDGER — why each suppressed function cannot currently be typechecked
# ============================================================================
#
# --- erlang_types: minimization FFI / array-as-tuple internals --------------
# dnf_ty_{tuple,function,list,map,variable}:_minimize_all_lines_from_dnf/5
# dnf_ty_{...}:_minimize_espresso/1
# dnf_ty_{...}:_collect_port_output/2
#     These shell out to the external `espresso` minimizer over a port and
#     marshal results through tuples-used-as-arrays. The port protocol and the
#     setelement/element array access are outside what the checker models.
# dnf_ty_{...}:reorder_if_needed/5
#     Needs refinement of comparison-operator results (`<`/`>` on opaque keys)
#     that the checker does not track.
# dnf_ty_{...}:replace_index/4
#     erlang:setelement/3 on a tuple used as a mutable array; not modeled.
#
# --- erlang_types: integer guard refinement ---------------------------------
# ty_node:compare/2
# dnf_ty_interval:compare_int/2
# dnf_ty_interval:unparse_single/1
#     Exhaustiveness depends on integer-range refinement through `<`/`>=`
#     guards that the checker does not perform.
# dnf_ty_interval:_collect_port_output/2  -- same FFI reason as above.
#
# --- erlang_types: bitstring descriptors ------------------------------------
# dnf_ty_predefined:is_empty/2
# dnf_ty_predefined:unparse/2
#     Need a richer bitstring type than is currently expressible.
#
# --- erlang_types: ty_parser (separate parsing layer) -----------------------
# ty_parser:convert/3, parse/1, unify/2, set_symtab/1, group/3
#     ty_parser is excluded from the erlang_types self-check historically.
# ============================================================================

./ety \
    -P . \
    -S ./src \
    -I ./include \
    -I ./src \
    -I ./src/erlang_types \
    -I ./src/erlang_types/dnf \
    --report-mode report \
    --report-timeout 10000 \
    -l error \
    --type-overlay overlays/etylizer_overlay.erl \
    --no-deps \
    -i 'ty_parser:convert/3' \
    -i 'ty_parser:parse/1' \
    -i 'ty_parser:unify/2' \
    -i 'ty_parser:set_symtab/1' \
    -i 'ty_parser:group/3' \
    -i 'dnf_ty_predefined:is_empty/2' \
    -i 'dnf_ty_predefined:unparse/2' \
    -i 'ty_node:compare/2' \
    -i "dnf_ty_interval:'_collect_port_output'/2" \
    -i 'dnf_ty_interval:compare_int/2' \
    -i 'dnf_ty_interval:unparse_single/1' \
    -i 'dnf_ty_tuple:reorder_if_needed/5' \
    -i "dnf_ty_tuple:'_minimize_all_lines_from_dnf'/5" \
    -i "dnf_ty_tuple:'_minimize_espresso'/1" \
    -i "dnf_ty_tuple:'_collect_port_output'/2" \
    -i "dnf_ty_tuple:replace_index/4" \
    -i 'dnf_ty_function:reorder_if_needed/5' \
    -i "dnf_ty_function:'_minimize_all_lines_from_dnf'/5" \
    -i "dnf_ty_function:'_minimize_espresso'/1" \
    -i "dnf_ty_function:'_collect_port_output'/2" \
    -i "dnf_ty_function:replace_index/4" \
    -i 'dnf_ty_list:reorder_if_needed/5' \
    -i "dnf_ty_list:'_minimize_all_lines_from_dnf'/5" \
    -i "dnf_ty_list:'_minimize_espresso'/1" \
    -i "dnf_ty_list:'_collect_port_output'/2" \
    -i "dnf_ty_list:replace_index/4" \
    -i 'dnf_ty_map:reorder_if_needed/5' \
    -i "dnf_ty_map:'_minimize_all_lines_from_dnf'/5" \
    -i "dnf_ty_map:'_minimize_espresso'/1" \
    -i "dnf_ty_map:'_collect_port_output'/2" \
    -i "dnf_ty_map:replace_index/4" \
    -i 'dnf_ty_variable:reorder_if_needed/5' \
    -i "dnf_ty_variable:'_minimize_all_lines_from_dnf'/5" \
    -i "dnf_ty_variable:'_minimize_espresso'/1" \
    -i "dnf_ty_variable:'_collect_port_output'/2" \
    -i "dnf_ty_variable:replace_index/4" \
    "$@"
